# SonAI local environment — copy this file to .env and fill in your values.
# .env is git-ignored and will never be committed.

# Required: Your Anthropic API key for Claude-powered agent features
ANTHROPIC_API_KEY=your-api-key-here

# Optional: SuperCollider connection (defaults shown)
# SC_HOST=127.0.0.1
# SC_SYNTH_PORT=57110
# SC_LANG_PORT=57120
